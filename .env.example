# Docker Compose environment defaults for the AI Platform foundation.
# Copy this file to .env before starting services when you want to override values:
#   cp .env.example .env

# Project name used by Docker Compose for containers, networks, and volumes.
COMPOSE_PROJECT_NAME=ai-platform-lab

# Ollama configuration
OLLAMA_HOST_PORT=11434
OLLAMA_CONTAINER_PORT=11434
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_KEEP_ALIVE=24h

# Open WebUI placeholder configuration
# Enable the optional profile with: docker compose --profile webui up -d
OPEN_WEBUI_HOST_PORT=3000
OPEN_WEBUI_CONTAINER_PORT=8080
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main

# Qdrant placeholder configuration
# Enable the optional profile with: docker compose --profile vector-db up -d
QDRANT_HTTP_HOST_PORT=6333
QDRANT_HTTP_CONTAINER_PORT=6333
QDRANT_GRPC_HOST_PORT=6334
QDRANT_GRPC_CONTAINER_PORT=6334
QDRANT_IMAGE=qdrant/qdrant:latest
